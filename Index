<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Meenakshii Guupta — Senior UI/UX Designer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet" />

  <style>
    /* ── TOKENS ──────────────────────────────────────────────── */
    :root {
      --cream:    #F7F5F0;
      --ink:      #181614;
      --ink-60:   rgba(24,22,20,.60);
      --ink-30:   rgba(24,22,20,.30);
      --ink-10:   rgba(24,22,20,.10);
      --accent:   #C87941;
      --accent-l: #F0DEC8;
      --white:    #FFFFFF;
      --r-m: 16px; --r-l: 24px;
      --sh-s: 0 2px 12px rgba(24,22,20,.07);
      --sh-m: 0 8px 32px rgba(24,22,20,.10);
      --sh-l: 0 20px 60px rgba(24,22,20,.12);
      --nav-h: 68px;
      --max-w: 1120px;
      --serif: 'DM Serif Display', Georgia, serif;
      --sans:  'DM Sans', system-ui, sans-serif;
      --ease:  cubic-bezier(.22,1,.36,1);
    }

    /* ── RESET ───────────────────────────────────────────────── */
    *,*::before,*::after { box-sizing:border-box; margin:0; padding:0 }
    html { scroll-behavior:smooth }
    body { font-family:var(--sans); background:var(--cream); color:var(--ink); -webkit-font-smoothing:antialiased; overflow-x:hidden }
    a { color:inherit; text-decoration:none }
    img { display:block; max-width:100% }
    button { cursor:pointer; font-family:var(--sans); border:none; background:none }

    /* Subtle grain */
    body::before { content:''; position:fixed; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E"); pointer-events:none; z-index:9999; opacity:.4 }

    .container { max-width:var(--max-w); margin:0 auto; padding:0 32px }

    /* ── TYPE ────────────────────────────────────────────────── */
    .t-label { font-size:.72rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--ink-60) }
    .t-h1    { font-family:var(--serif); font-size:clamp(1.8rem,3.5vw,3rem); line-height:1.12; letter-spacing:-.02em }
    .t-body  { font-size:1rem; line-height:1.72; color:var(--ink-60); font-weight:300 }

    /* ── BUTTONS ─────────────────────────────────────────────── */
    .btn { display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border-radius:100px; font-size:.9rem; font-weight:500; transition:transform .2s var(--ease), box-shadow .2s var(--ease), background .2s }
    .btn:hover { transform:translateY(-2px) }
    .btn-primary { background:var(--ink); color:var(--white); box-shadow:0 4px 20px rgba(24,22,20,.25) }
    .btn-primary:hover { background:#2a2724; box-shadow:var(--sh-m) }
    .btn-outline { background:transparent; color:var(--ink); border:1.5px solid var(--ink-30) }
    .btn-outline:hover { border-color:var(--ink); background:var(--ink-10) }

    /* ── NAVBAR ──────────────────────────────────────────────── */
    .nav { position:fixed; top:0; left:0; right:0; height:var(--nav-h); background:rgba(247,245,240,.9); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); border-bottom:1px solid var(--ink-10); z-index:1000; transition:box-shadow .3s }
    .nav.scrolled { box-shadow:var(--sh-s) }
    .nav-inner { max-width:var(--max-w); margin:0 auto; padding:0 32px; height:100%; display:flex; align-items:center; justify-content:space-between }
    .nav-logo { font-family:var(--serif); font-size:1.15rem }
    .nav-logo span { color:var(--accent) }
    .nav-contact { padding:9px 22px; border-radius:100px; background:var(--ink); color:var(--white); font-size:.88rem; font-weight:500; transition:background .2s }
    .nav-contact:hover { background:var(--accent) }

    /* ═══════════════════════════════════════════════════════════
       HERO  —  LEFT: text  |  RIGHT: image
    ═══════════════════════════════════════════════════════════ */
    .hero { min-height:100vh; display:flex; align-items:center; padding-top:calc(var(--nav-h) + 56px); padding-bottom:80px }
    .hero-inner {
      display:grid;
      grid-template-columns: 1fr 380px;   /* left=text, right=photo */
      gap:72px;
      align-items:center;
    }

    /* LEFT side */
    .hero-content {}
    .hero-eyebrow { display:inline-flex; align-items:center; gap:8px; background:var(--accent-l); color:var(--accent); padding:6px 14px; border-radius:100px; font-size:.78rem; font-weight:600; letter-spacing:.07em; text-transform:uppercase; margin-bottom:28px }
    .hero-eyebrow::before { content:''; width:6px; height:6px; background:var(--accent); border-radius:50%; animation:pulse 2s infinite }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.7)} }

    .hero-name { font-family:var(--serif); font-size:clamp(2.8rem,5.5vw,5rem); line-height:1.06; letter-spacing:-.025em; margin-bottom:10px }
    .hero-name em { font-style:italic; color:var(--accent) }
    .hero-designation { font-size:.82rem; font-weight:500; color:var(--ink-60); letter-spacing:.06em; text-transform:uppercase; margin-bottom:22px }
    .hero-subtitle { font-size:1rem; line-height:1.68; color:var(--ink-60); font-weight:300; max-width:500px; margin-bottom:36px }
    .hero-cta { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:48px }

    /* Metrics strip under buttons */
    .hero-metrics { display:flex; gap:36px; padding-top:36px; border-top:1px solid var(--ink-10); flex-wrap:wrap }
    .metric-num   { font-family:var(--serif); font-size:2rem; letter-spacing:-.03em }
    .metric-label { font-size:.76rem; color:var(--ink-60); margin-top:2px }

    /* RIGHT side — photo */
    .hero-image { position:relative }
    .hero-image-wrap { border-radius:var(--r-l); overflow:hidden; aspect-ratio:4/5; background:var(--ink-10); position:relative }
    .hero-image-wrap img { width:100%; height:100%; object-fit:cover; transition:transform .6s var(--ease) }
    .hero-image-wrap:hover img { transform:scale(1.03) }

    /* Placeholder avatar */
    .avatar-ph { width:100%; height:100%; background:linear-gradient(135deg,#e8e0d5,#d4c8b8); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px; color:var(--ink-30) }
    .avatar-ph svg { width:72px; opacity:.4 }
    .avatar-ph p { font-size:.74rem; letter-spacing:.12em; text-transform:uppercase }

    /* Open-to-work badge over image */
    .otw-badge { position:absolute; bottom:18px; left:50%; transform:translateX(-50%); background:var(--white); border-radius:100px; padding:8px 16px 8px 10px; display:flex; align-items:center; gap:8px; box-shadow:var(--sh-m); white-space:nowrap; font-size:.78rem; font-weight:500 }
    .otw-dot { width:8px; height:8px; border-radius:50%; background:#22C55E; box-shadow:0 0 0 3px rgba(34,197,94,.2) }

    /* Decorative circles behind image */
    .hero-deco { position:absolute; top:-18px; right:-18px; width:110px; height:110px; border:1.5px solid var(--ink-10); border-radius:50%; pointer-events:none }
    .hero-deco::after { content:''; position:absolute; inset:16px; border:1.5px solid var(--ink-10); border-radius:50% }

    /* Mobile: stack image above text */
    @media(max-width:900px) {
      .hero-inner { grid-template-columns:1fr; gap:48px }
      .hero-image { max-width:300px; margin:0 auto; width:100%; order:-1 }
    }
    @media(max-width:480px) { .hero-metrics { gap:20px } }

    /* ═══════════════════════════════════════════════════════════
       TAB BAR  —  Profile | Portfolio  (underline style only)
    ═══════════════════════════════════════════════════════════ */
    .tab-bar-wrap {
      position:sticky; top:var(--nav-h); z-index:900;
      background:rgba(247,245,240,.93);
      backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
      border-bottom:1px solid var(--ink-10);
    }
    .tab-bar {
      max-width:var(--max-w); margin:0 auto; padding:0 32px;
      display:flex; position:relative;
    }
    /* The two tab buttons — plain text, no background */
    .main-tab {
      padding:22px 36px 18px;
      font-size:1rem; font-weight:500;
      color:var(--ink-60);
      cursor:pointer;
      transition:color .25s;
      background:none; border:none;
      letter-spacing:.01em;
      user-select:none;
    }
    .main-tab:hover  { color:var(--ink) }
    .main-tab.active { color:var(--ink) }

    /* Sliding underline */
    .tab-underline {
      position:absolute; bottom:0; height:2px;
      background:var(--ink); border-radius:2px 2px 0 0;
      transition:left .38s var(--ease), width .38s var(--ease);
    }

    /* Tab panels */
    .tab-panel { display:none }
    .tab-panel.active { display:block }

    /* ── SHARED SECTION HELPERS ──────────────────────────────── */
    .section-block { padding:72px 0 }
    .section-label { display:flex; align-items:center; gap:12px; margin-bottom:20px }
    .section-label::after { content:''; flex:1; height:1px; background:var(--ink-10); max-width:60px }

    /* ═══════════════════════════════════════════════════════════
       PROFILE PANEL STYLES
    ═══════════════════════════════════════════════════════════ */
    /* About grid */
    .about-grid { display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:start; margin-bottom:72px }
    @media(max-width:768px) { .about-grid { grid-template-columns:1fr; gap:48px } }

    .about-tags { display:flex; flex-wrap:wrap; gap:8px; margin-top:22px }
    .tag { padding:6px 14px; border-radius:100px; background:var(--white); font-size:.82rem; font-weight:500; color:var(--ink-60); border:1px solid var(--ink-10); transition:all .2s }
    .tag:hover { background:var(--accent-l); color:var(--accent); border-color:var(--accent-l) }

    /* Timeline */
    .tl-item { display:grid; grid-template-columns:88px 1fr; gap:20px; padding:26px 0; border-bottom:1px solid var(--ink-10); position:relative }
    .tl-item:last-child { border-bottom:none }
    .tl-year { font-size:.74rem; font-weight:600; color:var(--ink-30); padding-top:4px; line-height:1.5 }
    .tl-dot { position:absolute; left:81px; top:33px; width:8px; height:8px; border-radius:50%; background:var(--ink-10); border:2px solid var(--cream); box-shadow:0 0 0 2px var(--ink-30) }
    .tl-item:first-child .tl-dot { background:var(--accent); box-shadow:0 0 0 2px var(--accent) }
    .tl-role    { font-weight:600; font-size:.95rem; margin-bottom:3px }
    .tl-company { font-size:.85rem; color:var(--accent); font-weight:500; margin-bottom:6px }
    .tl-desc    { font-size:.84rem; color:var(--ink-60); line-height:1.65 }

    /* Achievements */
    .ach-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:72px }
    @media(max-width:800px) { .ach-grid { grid-template-columns:repeat(2,1fr) } }
    .ach-card { background:var(--white); border:1px solid var(--ink-10); border-radius:var(--r-m); padding:24px; transition:all .25s var(--ease) }
    .ach-card:hover { box-shadow:var(--sh-m); transform:translateY(-3px) }
    .ach-num   { font-family:var(--serif); font-size:2rem; color:var(--accent) }
    .ach-label { font-size:.82rem; color:var(--ink-60); margin-top:4px; line-height:1.45 }

    /* Design process dark card */
    .process-card { background:var(--ink); border-radius:var(--r-l); padding:56px }
    @media(max-width:640px) { .process-card { padding:32px 20px } }
    .process-steps { display:grid; grid-template-columns:repeat(6,1fr); gap:0; margin-top:52px; position:relative }
    .process-steps::before { content:''; position:absolute; top:25px; left:32px; right:32px; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,.16) 10%,rgba(255,255,255,.16) 90%,transparent); pointer-events:none }
    @media(max-width:900px) { .process-steps { grid-template-columns:repeat(3,1fr); gap:36px } .process-steps::before { display:none } }
    @media(max-width:540px) { .process-steps { grid-template-columns:repeat(2,1fr); gap:28px } }
    .ps-item { display:flex; flex-direction:column; align-items:center; text-align:center; padding:0 8px }
    .ps-icon { width:50px; height:50px; border-radius:50%; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.13); display:flex; align-items:center; justify-content:center; font-size:1.15rem; margin-bottom:14px; position:relative; z-index:1; transition:all .3s var(--ease) }
    .ps-item:hover .ps-icon { background:var(--accent); border-color:var(--accent); transform:scale(1.1) }
    .ps-num   { font-size:.6rem; color:rgba(255,255,255,.26); margin-bottom:4px; letter-spacing:.12em; text-transform:uppercase }
    .ps-title { font-weight:600; font-size:.9rem; color:#fff; margin-bottom:5px }
    .ps-desc  { font-size:.74rem; color:rgba(255,255,255,.36); line-height:1.55 }

    /* ═══════════════════════════════════════════════════════════
       PORTFOLIO PANEL STYLES
    ═══════════════════════════════════════════════════════════ */
    .portfolio-intro { display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:end; margin-bottom:48px }
    @media(max-width:768px) { .portfolio-intro { grid-template-columns:1fr; gap:24px } }
    .strength-list  { margin-top:16px; display:flex; flex-direction:column; gap:10px }
    .strength-item  { display:flex; align-items:center; gap:12px; font-size:.9rem; color:var(--ink-60) }
    .strength-item::before { content:''; width:16px; height:1px; background:var(--accent); flex-shrink:0 }

    /* Filter bar */
    .filter-bar { display:flex; gap:6px; flex-wrap:wrap; padding:5px; background:var(--white); border:1px solid var(--ink-10); border-radius:100px; margin-bottom:40px; width:fit-content }
    .filter-btn { padding:7px 18px; border-radius:100px; font-size:.82rem; font-weight:500; color:var(--ink-60); transition:all .2s var(--ease) }
    .filter-btn.active { background:var(--ink); color:var(--white) }
    .filter-btn:hover:not(.active) { background:var(--ink-10); color:var(--ink) }

    /* Cards */
    .projects-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:24px }
    @media(max-width:680px) { .projects-grid { grid-template-columns:1fr } }
    .project-card { background:var(--white); border:1px solid var(--ink-10); border-radius:var(--r-l); overflow:hidden; transition:all .35s var(--ease); display:flex; flex-direction:column }
    .project-card:hover { box-shadow:var(--sh-l); transform:translateY(-5px) }
    .project-card.hidden { display:none }
    .card-thumb { aspect-ratio:16/9; overflow:hidden; position:relative }
    .card-thumb img { width:100%; height:100%; object-fit:cover; transition:transform .5s var(--ease) }
    .project-card:hover .card-thumb img { transform:scale(1.06) }
    .card-thumb::after { content:''; position:absolute; inset:0; background:linear-gradient(to top,rgba(24,22,20,.26),transparent); opacity:0; transition:opacity .3s }
    .project-card:hover .card-thumb::after { opacity:1 }
    .thumb-ph { width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px }
    .thumb-ph svg { width:44px; opacity:.35 }
    .card-body   { padding:26px; flex:1; display:flex; flex-direction:column }
    .card-meta   { display:flex; align-items:center; gap:10px; margin-bottom:12px }
    .card-tag    { padding:4px 10px; border-radius:100px; background:var(--accent-l); color:var(--accent); font-size:.7rem; font-weight:600; letter-spacing:.06em; text-transform:uppercase }
    .card-year   { font-size:.75rem; color:var(--ink-30) }
    .card-title  { font-family:var(--serif); font-size:1.2rem; margin-bottom:8px; line-height:1.25 }
    .card-desc   { font-size:.85rem; color:var(--ink-60); line-height:1.65; flex:1 }
    .card-footer { display:flex; align-items:center; justify-content:space-between; margin-top:20px; padding-top:16px; border-top:1px solid var(--ink-10) }
    .card-tools  { font-size:.74rem; color:var(--ink-30) }
    .card-link   { display:inline-flex; align-items:center; gap:5px; font-size:.83rem; font-weight:500; color:var(--accent); transition:gap .2s }
    .card-link:hover { gap:9px }
    .card-link svg { width:13px }
    .portfolio-cta { text-align:center; margin-top:48px }

    /* ═══════════════════════════════════════════════════════════
       FOOTER  — photo + contact details only
    ═══════════════════════════════════════════════════════════ */
    footer { background:var(--ink); padding:52px 0 36px }
    .footer-inner { max-width:var(--max-w); margin:0 auto; padding:0 32px }

    /* Photo row */
    .footer-top { display:flex; align-items:center; gap:24px; margin-bottom:36px; padding-bottom:36px; border-bottom:1px solid rgba(255,255,255,.08) }
    .footer-photo { width:70px; height:70px; border-radius:50%; overflow:hidden; background:rgba(255,255,255,.1); flex-shrink:0 }
    .footer-photo img { width:100%; height:100%; object-fit:cover }
    .footer-photo-ph { width:100%; height:100%; display:flex; align-items:center; justify-content:center }
    .footer-photo-ph svg { width:30px; opacity:.3; color:#fff }
    .f-name { font-family:var(--serif); color:#fff; font-size:1.05rem; margin-bottom:3px }
    .f-role { font-size:.8rem; color:rgba(255,255,255,.42) }

    /* Bottom row */
    .footer-bottom { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:18px }
    .footer-links  { display:flex; gap:20px; flex-wrap:wrap }
    .footer-link   { font-size:.83rem; color:rgba(255,255,255,.4); display:flex; align-items:center; gap:6px; transition:color .2s }
    .footer-link:hover { color:#fff }
    .footer-link svg { width:13px }
    .footer-copy   { font-size:.75rem; color:rgba(255,255,255,.26) }

    /* ── REVEAL ANIMATION ────────────────────────────────────── */
    .reveal { opacity:0; transform:translateY(22px); transition:opacity .6s var(--ease), transform .6s var(--ease) }
    .reveal.visible { opacity:1; transform:none }
    .rd1 { transition-delay:.1s } .rd2 { transition-delay:.2s } .rd3 { transition-delay:.3s }
  </style>
</head>
